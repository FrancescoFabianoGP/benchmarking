# Copy this file to `.env` and fill in the secrets locally.
# `.env` is gitignored in this repo.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_GATEWAY_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-5
ANTHROPIC_MODEL=claude-sonnet-4-6
BENCHMARK_FRAMEWORK_MODEL=gpt-4o-mini

# Optional per-framework overrides
AUTOGEN_REACT_MODEL=
AUTOGEN_MULTI_AGENT_MODEL=
LANGGRAPH_MODEL=
METAGPT_MODEL=

# Optional OpenAI-compatible endpoint override
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
ANTHROPIC_VERSION=2023-06-01

# Optional Cloudflare ZDR settings used directly by Zeus.
# If these are blank, the benchmark harness will try to derive them from
# OPENAI_BASE_URL / ANTHROPIC_BASE_URL and OPENAI_API_KEY.
CLOUDFLARE_ZDR_AI_GATEWAY_BASE_URL=
CLOUDFLARE_ZDR_AI_GATEWAY_API_KEY=

# Optional local workflow cache for Zeus. If blank, the benchmark harness will
# default Zeus runs to a repo-local cache directory.
CACHE_URI=

# Zeus baseline runtime
GCLOUD_LOCAL_CREDENTIALS=true
GP_BENCHMARK_COACTION_DATA_ROOT=
